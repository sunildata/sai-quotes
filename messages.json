[
  { "id": "sai-001", "text": "Why fear when I am here.",                            "source": "Sai Baba" },
  { "id": "sai-002", "text": "Sabka Malik Ek.",                                     "source": "Sai Baba" },
  { "id": "sai-003", "text": "Trust in me and your prayer shall be answered.",     "source": "Sai Baba" },
  { "id": "sai-004", "text": "Allah Malik.",                                        "source": "Sai Baba" },
  { "id": "sai-005", "text": "Be patient. Time is the best teacher.",              "source": "Sai Baba" },
  { "id": "sai-006", "text": "Work is worship. Duty is God.",                       "source": "Sai Baba" }
]
